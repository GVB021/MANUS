# Server Configuration
PORT=5002
NODE_ENV=production
NIXPACKS_PROVIDERS=node,python

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database?pgbouncer=true&sslmode=require

# Session & Security
SESSION_SECRET=your-super-secret-key-here-change-in-production
NODE_TLS_REJECT_UNAUTHORIZED=0

# Supabase Integration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Daily.co Integration (for video conferencing)
DAILY_API_KEY=your-daily-api-key

# AWS S3 (optional, for file uploads)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
